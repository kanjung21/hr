# ===== PostgreSQL Database Configuration =====
# Recommended: use either DATABASE_URL or individual params.

# Full connection URL (preferred)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hr_management"

# Individual connection parameters (fallback)
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="hr_management"
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_SSL="false"

# Backend settings
BACKEND_PORT="3001"
JWT_SECRET="change_this_to_a_strong_secret"

# Supabase (for legacy code paths, optional)
VITE_SUPABASE_URL="http://127.0.0.1:54321"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.localanon"
