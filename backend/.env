# Backend Configuration
BACKEND_PORT=3001

# JWT Secret (สำหรับการเข้ารหัส Token - ควรเปลี่ยนเป็นค่าที่ซับซ้อนในการใช้งานจริง)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hr_management
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Optional: Full Database URL (ใช้หากต้องการระบุแบบ connection string)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hr_management

# CORS Configuration (ถ้าต้องการจำกัด)
# CORS_ORIGIN=http://localhost:5173

# Node Environment
NODE_ENV=development
